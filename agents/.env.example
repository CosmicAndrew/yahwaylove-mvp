# YAHWAYLOVE Agent Environment Variables
# Copy this file to .env and fill in your values

# ── REQUIRED for Sprint (CONTENT Agent) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...          # Claude API — get at console.anthropic.com

# ── LIVE (already configured) ────────────────────────────────────────────────
# Muapi.ai production key — for AI media generation (Muapi.ai REST API)
MUAPI_API_KEY=                        # Set in Vercel env vars

# ── PENDING (retainer tier only) ─────────────────────────────────────────────
META_APP_ID=                          # Meta Marketing API — ARIA agent
META_APP_SECRET=                      # Meta Marketing API — ARIA agent
HUBSPOT_API_KEY=                      # HubSpot CRM — FUNNEL agent
TWILIO_ACCOUNT_SID=                   # SMS — HERALD agent
TWILIO_AUTH_TOKEN=                    # SMS — HERALD agent
TWILIO_PHONE_NUMBER=+1...             # Outbound SMS/Voice
VAPI_API_KEY=                         # AI voice calls — VOICE agent
SENDGRID_API_KEY=                     # Transactional email — HERALD agent
SUPABASE_URL=                         # Leads database — FUNNEL agent
SUPABASE_KEY=                         # Leads database — FUNNEL agent
GOOGLE_ANALYTICS_KEY=                 # GA4 — PULSE agent
