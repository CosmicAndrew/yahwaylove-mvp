# YAHWAYLOVE — Agent Environment Variables
# Copy to .env and fill in your keys. Never commit .env to GitHub.

# ─── REQUIRED (Sprint phase) ──────────────────────────────────────────────────

# Anthropic — powers ALL agents (CONTENT, EDITOR, DIRECTOR, VOICE PROFILER)
# Get at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── DISTRIBUTION (Tier 1 Sprint delivery) ───────────────────────────────────

# Blotato — auto-schedules posts across LinkedIn, Instagram, X, Facebook, TikTok
# Get at: https://blotato.com (free trial: 5,000 credits)
# Enables: python sprint_runner.py --form form.json --distribute
BLOTATO_API_KEY=blotato_...
BLOTATO_DEFAULT_ACCOUNT_ID=

# ─── DISCOVERY (SCOUT agent — Grok multi-agent search) ───────────────────────

# Grok / xAI — SuperGrok $30/mo gives API access
# Enables: python scout_agent.py --run --limit 50
# Get at: https://x.com/premium → SuperGrok → API
GROK_API_KEY=xai-...

# ─── MEDIA (Muapi.ai — 200+ AI models for image/video generation) ─────────────

# Muapi.ai — $20 credit already loaded
# Powers image generation for posts and ad creatives
MUAPI_PRODUCTION_KEY=muapi_...

# ─── OUTREACH (HERALD agent — email + SMS) ───────────────────────────────────

# SendGrid — transactional email (free tier: 100 emails/day)
# Get at: https://sendgrid.com
SENDGRID_API_KEY=SG....

# Twilio — SMS follow-ups within 5 min of inquiry
# Get at: https://twilio.com
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_FROM_NUMBER=+1...

# ─── CRM (FUNNEL agent — HubSpot lead tracking) ──────────────────────────────

# HubSpot — lead capture, deal stages, email sequences
# Get at: https://app.hubspot.com → Settings → Integrations → API Key
HUBSPOT_API_KEY=...

# ─── ADS (ARIA agent — Meta Ads — retainer tier only) ────────────────────────

# Meta Business API — needed for ARIA (Facebook/Instagram ads)
# Get at: https://developers.facebook.com
META_APP_ID=...
META_APP_SECRET=...
META_ACCESS_TOKEN=...

# ─── VOICE (VOICE agent — AI calls — high-tier retainer only) ────────────────

# VAPI.ai — AI phone call agent
# Get at: https://vapi.ai
VAPI_API_KEY=...

# ─── DATABASE (FUNNEL + PULSE — lead tracking + analytics) ───────────────────

# Supabase — leads table, prospect tracking, agent logs
# Get at: https://supabase.com (free tier available)
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_KEY=eyJ...

# ─── ANALYTICS (PULSE agent) ─────────────────────────────────────────────────

# Google Analytics 4 — site traffic + conversion tracking
GOOGLE_ANALYTICS_KEY=...

# ─── DEPLOYMENT (Already live) ───────────────────────────────────────────────

# These are already configured — don't overwrite unless rotating keys
# VERCEL_TOKEN — auto-deploy on GitHub push
# GITHUB_TOKEN — repo access for BUILD agent
# FORMSPREE_ID — xwpbbzvy (routes to rocha@yahwaylove.com)

# ─── TELEGRAM (ShipClaw — agent deployment to Telegram) ──────────────────────

# ShipClaw — deploy agents to Telegram in 30 seconds
# Get at: https://shipclaw.org
SHIPCLAW_TOKEN=...
TELEGRAM_BOT_TOKEN=...
